# SPKT Digital — Environment Variables (opsional)
# Salin ke .env.local untuk development

# Folder data & SQLite (default: ./data)
DATA_DIR=./data

# Path database (default: DATA_DIR/spkt.db)
# DATABASE_PATH=./data/spkt.db

# Folder upload fisik (default: DATA_DIR/uploads)
# UPLOAD_DIR=./data/uploads

# Wajibkan admin mengaktifkan 2FA sebelum login (default: tidak)
# REQUIRE_ADMIN_2FA=true

# Node environment (otomatis di Next.js)
# NODE_ENV=development
